FIREBASE_SERVICE_ACCOUNT_JSON=
# FIREBASE_SERVICE_ACCOUNT_JSON can be plain JSON or base64-encoded JSON.

# Alternative to FIREBASE_SERVICE_ACCOUNT_JSON:
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional server-side admin email check used in replies endpoint
ADMIN_EMAIL=

# Optional comma-separated allowlist for frontend origins in CORS
# Example: https://giftandsonsinternational.com,https://gift-and-sons.vercel.app
FRONTEND_ORIGINS=