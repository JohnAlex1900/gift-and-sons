{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "node",
    "baseUrl": ".", // Base directory for module resolution
    "typeRoots": ["./node_modules/@types", "./types"],
    "types": ["node", "express"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["**/*", "types/**/*"], // Include the shared directory
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
