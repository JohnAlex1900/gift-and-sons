{
  "version": 2,
  "builds": [
    {
      "src": "dist/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "dist/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "dist/public/$1",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" }
    }
  ],
  "static": {
    "directory": "dist/public"
  },
  "env": {
    "NODE_ENV": "production"
  }
}
