{
  "functions": {
    "api/*.js": {
      "includeFiles": "server/dist/**"
    },
    "api/**/*.js": {
      "includeFiles": "server/dist/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/[...path].js?path=$1" },
    { "source": "/((?!api(?:/|$)).*)", "destination": "/index.html" }
  ],
  "redirects": [],
  "headers": []
}
