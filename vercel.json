{
  "functions": {
    "api/*.js": {
      "includeFiles": "server/dist/**"
    },
    "api/**/*.js": {
      "includeFiles": "server/dist/**"
    }
  },
  "rewrites": [
    { "source": "/((?!api(?:/|$)).*)", "destination": "/index.html" }
  ],
  "redirects": [],
  "headers": []
}
{
  "functions": {
    "api/*.js": {
      "includeFiles": "server/dist/**",
      "runtime": "nodejs20.x"
    },
    "api/**/*.js": {
      "includeFiles": "server/dist/**",
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    { "source": "/((?!api(?:/|$)).*)", "destination": "/index.html" }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
